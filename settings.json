{
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "disable_ai": true,
  "project_panel": {
    "dock": "right",
  },
  "theme": "Ayu Dark",
  "agent": {
    "default_profile": "write",
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "model_parameters": [],
  },
  "vim_mode": true,
  "languages": {
    "Python": {
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["--stdin-filename", "{buffer_path}", "-"],
        },
      },
      // Or use `"formatter": null` to disable formatting entirely.
    },
  },
}
